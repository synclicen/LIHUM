// LIHUM: Lihat untuk Umum - Prisma schema
// Photo gallery with Google Drive integration, multi-role access control.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id              String   @id
  name            String
  description     String   @default("")
  driveFolderUrl  String
  driveFolderId   String
  displayMode     String   @default("all") // "all" | "search"
  autoSyncEnabled Boolean  @default(false)
  autoSyncInterval String  @default("3m") // "1m" | "3m" | "5m" | "1h" | "6h"
  lastSyncedAt    String   @default("")
  photoCount      Int      @default(0)
  createdAt       String
  photos          Photo[]
}

model Photo {
  id             String   // original Drive file id (NOT unique across projects)
  name           String
  mimeType       String   @default("")
  thumbnailLink  String   @default("")
  webContentLink String   @default("")
  size           String   @default("")
  createdTime    String   @default("")
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([projectId, id])
  @@index([projectId])
}

model Account {
  id          String @id
  email       String @unique
  role        String @default("manager") // "admin" | "manager"
  displayName String @default("")
  addedAt     String
}
