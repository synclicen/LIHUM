# ─────────────────────────────────────────────────────────────
# LIHUM environment variables
# ─────────────────────────────────────────────────────────────
#
# DATABASE_URL  — Turso libSQL connection string.
#                 • Local dev:  file:/absolute/path/to/custom.db
#                 • Turso cloud: libsql://<your-db>.turso.io
#
# TURSO_AUTH_TOKEN — Turso access token (only needed for the cloud URL,
#                    ignored for local file: URLs).
#
# APP_URL — Public URL of the deployed app (used to build absolute share
#           links + QR codes). On Cloudflare, set this to your
#           https://<project>.workers.dev (or custom domain) URL.

# ── Local development (sandbox) ──
DATABASE_URL=file:/home/z/my-project/db/custom.db
# TURSO_AUTH_TOKEN=

# ── Production (Turso + Cloudflare) — copy these into the Cloudflare dashboard ──
# DATABASE_URL=libsql://lihum-<your-org>.turso.io
# TURSO_AUTH_TOKEN=<your-turso-auth-token>
# APP_URL=https://lihum.<your-subdomain>.workers.dev
